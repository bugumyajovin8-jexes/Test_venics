# Supabase project config. These are PUBLIC by design (the anon key is safe to
# ship in the client) — the real security boundary is Row Level Security.
# Copy this file to .env and fill in your project's values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Gemini ("Venics Smart") API key.
# This is NOT a client variable — it is set as a Supabase Edge Function secret so
# it never reaches the browser bundle:
#   supabase secrets set GEMINI_API_KEY=<your-key>
#   supabase functions deploy gemini
